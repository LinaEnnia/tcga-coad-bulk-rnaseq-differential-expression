*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site
docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/


# Large generated/downloaded data
data/*.rds
data/*.csv
data/*.tsv
data/*.txt
data/*.gz

GDCdata/
*.rds
MANIFEST.txt

